<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="360"
        x:Class="UnrealPluginsGUI.Views.AboutWindow"
        Title="About"
        Width="520" Height="360">

    <Border Background="#FF252526" Padding="20">
        <StackPanel Spacing="12">
            <TextBlock Text="Unreal Plugins Manager"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"/>

            <TextBlock Text="Author: Yen chezky"
                       FontSize="14"
                       Foreground="#FFCCCCCC"/>

            <TextBlock Text="Telegram channel (portfolio):"
                       FontSize="14"
                       Foreground="#FFCCCCCC"/>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="https://t.me/yenchzk_archive"
                           FontSize="14"
                           Foreground="#FF007ACC"/>
                <Button Content="Open"
                        Click="OpenTelegram_OnClick"
                        Padding="10,3"/>
            </StackPanel>

            <TextBlock Text="GitHub:"
                       FontSize="14"
                       Foreground="#FFCCCCCC"/>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="https://github.com/yenichw"
                           FontSize="14"
                           Foreground="#FF007ACC"/>
                <Button Content="Open"
                        Click="OpenGitHub_OnClick"
                        Padding="10,3"/>
            </StackPanel>

            <Border Background="#FF2D2D30" Padding="12" CornerRadius="5" Margin="0,10,0,0">
                <TextBlock Text="Tip: Links open in your default browser."
                           FontSize="12"
                           Foreground="#FFCCCCCC"/>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Close" Click="Close_OnClick" Padding="12,4"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
